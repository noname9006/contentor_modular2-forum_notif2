<%- include('partials/header', { page: 'leaderboard' }) %>

<h1>Leaderboard</h1>

<!-- Stat cards -->
<div class="stat-grid">
  <div class="stat-card">
    <div class="label">Posts</div>
    <div class="value"><%= stats.totalPosts %></div>
  </div>
  <div class="stat-card">
    <div class="label">Total Votes</div>
    <div class="value"><%= stats.totalVotes %></div>
  </div>
  <div class="stat-card">
    <div class="label">Voters</div>
    <div class="value"><%= stats.totalVoters %></div>
  </div>
  <div class="stat-card">
    <div class="label">Authors</div>
    <div class="value"><%= stats.totalAuthors %></div>
  </div>
</div>

<!-- Timeframe tabs -->
<div class="timeframe-tabs">
  <% ['24h','7d','30d','90d','all'].forEach(tf => { %>
    <a href="/leaderboard?timeframe=<%= tf %>"
       class="<%= timeframe === tf ? 'active' : '' %>">
      <%= tf === '24h' ? '24h' : tf === '7d' ? '7 days' : tf === '30d' ? '30 days' : tf === '90d' ? '90 days' : 'All time' %>
    </a>
  <% }) %>
</div>

<div class="two-col">
  <!-- Top Voted Users -->
  <div class="card">
    <h2>🏆 Top Voted Users</h2>
    <div class="table-wrap" style="margin-top:1rem;">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>User</th>
            <th>Score</th>
            <th>Posts</th>
          </tr>
        </thead>
        <tbody>
          <% if (topVoted.length === 0) { %>
            <tr><td colspan="4" style="color:var(--text-muted);text-align:center;padding:2rem;">No data yet</td></tr>
          <% } %>
          <% topVoted.forEach((u, i) => { %>
            <tr>
              <td style="color:var(--text-muted)"><%= i + 1 %></td>
              <td>
                <% if (u.avatarUrl) { %>
                  <img src="<%= u.avatarUrl %>" class="avatar" alt="" />
                <% } else { %>
                  <span class="avatar-placeholder"></span>
                <% } %>
                <%= u.displayName %>
              </td>
              <td style="color:var(--accent);font-weight:700"><%= Number(u.score || 0).toFixed(1).replace(/\.0$/, '') %></td>
              <td><%= u.postCount %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Top Voters -->
  <div class="card">
    <h2>🗳️ Top Voters</h2>
    <div class="table-wrap" style="margin-top:1rem;">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>User</th>
            <th>Votes Cast</th>
          </tr>
        </thead>
        <tbody>
          <% if (topVoters.length === 0) { %>
            <tr><td colspan="3" style="color:var(--text-muted);text-align:center;padding:2rem;">No data yet</td></tr>
          <% } %>
          <% topVoters.forEach((u, i) => { %>
            <tr>
              <td style="color:var(--text-muted)"><%= i + 1 %></td>
              <td>
                <% if (u.avatarUrl) { %>
                  <img src="<%= u.avatarUrl %>" class="avatar" alt="" />
                <% } else { %>
                  <span class="avatar-placeholder"></span>
                <% } %>
                <%= u.displayName %>
              </td>
              <td style="color:var(--accent);font-weight:700"><%= u.votesCast %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
