<%- include('partials/header', { page: 'settings' }) %>

<style>
  input[type="number"] {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    padding: 8px 12px;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }
  input[type="number"]:focus { border-color: var(--accent); }

  .picker-wrap { position: relative; margin-bottom: 0.8rem; }

  .suggestions-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    z-index: 100;
    max-height: 240px;
    overflow-y: auto;
    margin-top: 2px;
  }
  .suggestion-item {
    padding: 8px 12px;
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--text);
  }
  .suggestion-item:hover { background: rgba(114,137,218,0.2); }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 0.85rem;
    color: var(--text);
  }
  .chip .rm-btn {
    background: none;
    border: none;
    color: var(--danger);
    cursor: pointer;
    font-size: 0.9rem;
    line-height: 1;
    padding: 0 2px;
  }

  .color-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
  }

  .role-item input[type="number"] { flex: 0 0 auto; width: 70px; }
</style>

<h1>Settings</h1>

<% if (saved) { %>
  <div class="alert alert-success">Settings saved successfully.</div>
<% } %>

<!-- ── Forum Channel ── -->
<div class="settings-section">
  <h2>Tracked Forum Channel</h2>
  <div id="loading-channels" style="color:var(--text-muted);font-size:0.85rem;margin-bottom:0.5rem">Loading channels…</div>
  <div id="channels-error" class="alert alert-error" style="display:none"></div>
  <div class="picker-wrap">
    <input type="text" id="channel-search" placeholder="Search channels…" autocomplete="off" />
    <div id="channel-suggestions" class="suggestions-dropdown" style="display:none"></div>
  </div>
  <div id="selected-channel-wrap" style="display:none;margin-bottom:0.8rem">
    <span class="chip">
      <span id="selected-channel-name"></span>
      <button type="button" class="rm-btn" onclick="clearChannel()">✕</button>
    </span>
  </div>
  <div id="thread-section" style="display:none">
    <div id="loading-threads" style="color:var(--text-muted);font-size:0.85rem;margin-bottom:0.5rem;display:none">Loading threads…</div>
    <div id="threads-error" class="alert alert-error" style="display:none"></div>
    <div class="picker-wrap">
      <input type="text" id="thread-search" placeholder="Filter threads (optional)…" autocomplete="off" />
      <div id="thread-suggestions" class="suggestions-dropdown" style="display:none"></div>
    </div>
    <div id="selected-thread-wrap" style="display:none;margin-bottom:0.8rem">
      <span class="chip">
        <span id="selected-thread-name"></span>
        <button type="button" class="rm-btn" onclick="clearThread()">✕</button>
      </span>
    </div>
  </div>
  <button type="button" class="btn btn-primary" onclick="saveChannel()">Save</button>
</div>

<!-- ── Tracked Roles ── -->
<div class="settings-section">
  <h2>Tracked Roles</h2>
  <div id="loading-roles" style="color:var(--text-muted);font-size:0.85rem;margin-bottom:0.5rem">Loading roles…</div>
  <div id="roles-error" class="alert alert-error" style="display:none"></div>
  <div class="picker-wrap">
    <input type="text" id="role-search" placeholder="Search roles…" autocomplete="off" />
    <div id="role-suggestions" class="suggestions-dropdown" style="display:none"></div>
  </div>
  <div class="role-list" id="role-list"></div>
  <button type="button" class="btn btn-primary" onclick="saveRoles()">Save Roles</button>
</div>

<!-- ── Multi-vote Mode ── -->
<div class="settings-section">
  <h2>Multi-vote Counting Mode</h2>
  <form id="form-mode">
    <div style="display:flex;flex-direction:column;gap:0.6rem;margin-bottom:1rem">
      <% ['highest','lowest','average','ignore'].forEach(mode => { %>
        <label style="display:flex;align-items:center;gap:0.6rem;cursor:pointer">
          <input type="radio" name="multi_vote_mode" value="<%= mode %>"
                 <%= settings.multi_vote_mode === mode ? 'checked' : '' %> />
          <span>
            <strong><%= mode %></strong>
            <span style="color:var(--text-muted);font-size:0.8rem">
              <% if (mode === 'highest') { %> — count only the highest emoji from each voter per post
              <% } else if (mode === 'lowest') { %> — count only the lowest emoji from each voter per post
              <% } else if (mode === 'average') { %> — average all emojis from each voter per post
              <% } else { %> — if a member reacts with multiple emojis under a single post, their vote is not counted
              <% } %>
            </span>
          </span>
        </label>
      <% }) %>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
  </form>
</div>

<!-- ── Vote Emojis ── -->
<div class="settings-section">
  <h2>Vote Emojis (in order, value 0–4)</h2>
  <form id="form-emojis">
    <div class="emoji-row">
      <%
        const emojis = Array.isArray(settings.vote_emojis) ? settings.vote_emojis : ['🧊','🌤️','⚡','🔥','💥'];
        const emojiWeights = Array.isArray(settings.vote_emoji_weights) ? settings.vote_emoji_weights : [0,1,2,3,4];
        emojis.forEach((emoji, i) => {
      %>
        <div class="form-group">
          <label>Value <%= i %></label>
          <input type="text" name="emoji_<%= i %>" value="<%= emoji %>" maxlength="8" style="text-align:center;font-size:1.3rem" />
          <label style="margin-top:0.4rem">Weight</label>
          <input type="number" name="emoji_weight_<%= i %>" value="<%= emojiWeights[i] !== undefined ? emojiWeights[i] : i %>" step="0.1" min="0" />
        </div>
      <% }) %>
    </div>
    <button type="submit" class="btn btn-primary">Save Emojis</button>
  </form>
</div>

<!-- ── Change Password ── -->
<div class="settings-section">
  <h2>Change Dashboard Password</h2>
  <form id="form-password">
    <div class="form-group">
      <label for="currentPassword">Current Password</label>
      <input type="password" id="currentPassword" name="currentPassword" autocomplete="current-password" />
    </div>
    <div class="form-group">
      <label for="newPassword">New Password <span style="color:var(--text-muted)">(min 8 characters)</span></label>
      <input type="password" id="newPassword" name="newPassword" autocomplete="new-password" />
    </div>
    <button type="submit" class="btn btn-primary">Change Password</button>
    <span id="pw-msg" style="margin-left:1rem;font-size:0.85rem"></span>
  </form>
</div>

<div id="save-msg" style="display:none;position:fixed;bottom:1.5rem;right:1.5rem;background:var(--success);color:#fff;padding:10px 18px;border-radius:8px;font-size:0.9rem;z-index:999"></div>

<script>
const CSRF_TOKEN = '<%= locals.csrfToken %>';
const INITIAL_ROLES = <%- JSON.stringify(Array.isArray(settings.tracked_roles) ? settings.tracked_roles : []) %>;
const INITIAL_FORUM_ID = <%- JSON.stringify(settings.tracked_forum_id || '') %>;

function showMsg(text, isError) {
  const el = document.getElementById('save-msg');
  el.textContent = text;
  el.style.background = isError ? 'var(--danger)' : 'var(--success)';
  el.style.display = 'block';
  setTimeout(() => { el.style.display = 'none'; }, 3000);
}

async function apiPost(url, data) {
  const res = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
    body: JSON.stringify(data)
  });
  return res.json();
}

function escapeHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
    .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

function colorToHex(color) {
  if (!color) return null;
  return '#' + color.toString(16).padStart(6, '0');
}

// ── Generic suggestion helpers ──────────────────────────────────────────────

function showSuggestions(dropId, items, onSelect) {
  const dropdown = document.getElementById(dropId);
  dropdown.innerHTML = '';
  if (!items.length) { dropdown.style.display = 'none'; return; }
  items.forEach(item => {
    const div = document.createElement('div');
    div.className = 'suggestion-item';
    div.textContent = item.name;
    div.addEventListener('mousedown', e => { e.preventDefault(); onSelect(item); });
    dropdown.appendChild(div);
  });
  dropdown.style.display = 'block';
}

function hideSuggestions(dropId) {
  const el = document.getElementById(dropId);
  if (el) el.style.display = 'none';
}

// ── Role picker ─────────────────────────────────────────────────────────────

let allRoles = [];
let selectedRoles = [];

async function loadRoles() {
  const loadingEl = document.getElementById('loading-roles');
  const errEl = document.getElementById('roles-error');
  loadingEl.style.display = 'block';
  errEl.style.display = 'none';
  try {
    const res = await fetch('/api/discord/roles');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    allRoles = data.roles || [];
    loadingEl.style.display = 'none';
  } catch {
    loadingEl.style.display = 'none';
    errEl.textContent = 'Failed to load roles from Discord.';
    errEl.style.display = 'block';
  }
  initSelectedRoles();
}

function initSelectedRoles() {
  selectedRoles = INITIAL_ROLES.map(r => {
    const match = allRoles.find(ar => ar.id === r.id);
    return {
      id: r.id,
      name: r.name || (match ? match.name : r.id),
      color: match ? (match.color || 0) : 0,
      position: r.position !== undefined ? r.position : (match ? (match.position || 0) : 0),
      weight: (typeof r.weight === 'number' && r.weight >= 0) ? r.weight : 1,
    };
  });
  renderSelectedRoles();
}

function renderSelectedRoles() {
  const list = document.getElementById('role-list');
  list.innerHTML = '';
  selectedRoles.forEach((role, i) => {
    const hex = colorToHex(role.color);
    const dotStyle = hex ? `background:${hex}` : 'background:var(--text-muted)';
    const div = document.createElement('div');
    div.className = 'role-item';
    const safeId = escapeHtml(role.id);
    div.innerHTML =
      `<span class="color-dot" style="${dotStyle}"></span>` +
      `<span style="flex:1;font-size:0.9rem">${escapeHtml(role.name)}</span>` +
      `<label style="font-size:0.82rem;color:var(--text-muted);margin:0;white-space:nowrap;display:flex;align-items:center;gap:0.3rem">` +
        `Weight` +
        `<input type="number" value="${role.weight}" step="0.1" min="0" style="width:70px;margin:0"` +
          ` oninput="updateRoleWeight('${safeId}', this.value)" />` +
      `</label>` +
      `<button type="button" class="rm-btn" onclick="removeSelectedRole(${i})">✕</button>`;
    list.appendChild(div);
  });
}

function updateRoleWeight(id, val) {
  const role = selectedRoles.find(r => r.id === id);
  if (role) role.weight = Math.max(0, parseFloat(val) || 0);
}

function removeSelectedRole(i) {
  selectedRoles.splice(i, 1);
  renderSelectedRoles();
}

function showRoleSuggestions(q) {
  const filtered = allRoles
    .filter(r => (!q || r.name.toLowerCase().includes(q)) && !selectedRoles.some(s => s.id === r.id))
    .slice(0, 8);
  showSuggestions('role-suggestions', filtered, selectRole);
}

document.getElementById('role-search').addEventListener('focus', function () {
  showRoleSuggestions('');
});

document.getElementById('role-search').addEventListener('input', function () {
  showRoleSuggestions(this.value.toLowerCase());
});

document.getElementById('role-search').addEventListener('blur', () => {
  setTimeout(() => hideSuggestions('role-suggestions'), 150);
});

function selectRole(role) {
  if (selectedRoles.some(r => r.id === role.id)) return;
  selectedRoles.push({ id: role.id, name: role.name, color: role.color || 0, position: role.position || 0, weight: 1 });
  renderSelectedRoles();
  document.getElementById('role-search').value = '';
  hideSuggestions('role-suggestions');
}

async function saveRoles() {
  const roles = selectedRoles
    .map(r => ({ id: r.id, name: r.name, position: r.position, weight: r.weight }))
    .sort((a, b) => b.position - a.position);
  const r = await apiPost('/api/settings', { tracked_roles: roles });
  showMsg(r.ok ? 'Roles saved!' : (r.error || 'Error'), !r.ok);
}

// ── Channel picker ───────────────────────────────────────────────────────────

let allChannels = [];
let selectedChannel = null;
let allThreads = [];
let selectedThread = null;
let _initialThreadPrePopDone = false;

async function loadChannels() {
  const loadingEl = document.getElementById('loading-channels');
  const errEl = document.getElementById('channels-error');
  loadingEl.style.display = 'block';
  errEl.style.display = 'none';
  try {
    const res = await fetch('/api/discord/channels');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    allChannels = data.channels || [];
    loadingEl.style.display = 'none';
    if (INITIAL_FORUM_ID) {
      const match = allChannels.find(c => c.id === INITIAL_FORUM_ID);
      if (match) {
        setSelectedChannel(match, false);
        fetchThreads(match.id);
      }
    }
  } catch {
    loadingEl.style.display = 'none';
    errEl.textContent = 'Failed to load channels from Discord.';
    errEl.style.display = 'block';
  }
}

function setSelectedChannel(channel, clearThreadState) {
  selectedChannel = channel;
  if (clearThreadState !== false) { selectedThread = null; updateThreadChip(); }
  document.getElementById('selected-channel-name').textContent = '#' + channel.name;
  document.getElementById('selected-channel-wrap').style.display = '';
  document.getElementById('channel-search').value = '';
  hideSuggestions('channel-suggestions');
  document.getElementById('thread-section').style.display = '';
}

function clearChannel() {
  selectedChannel = null;
  selectedThread = null;
  allThreads = [];
  document.getElementById('selected-channel-wrap').style.display = 'none';
  document.getElementById('thread-section').style.display = 'none';
  updateThreadChip();
}

function showChannelSuggestions(q) {
  const filtered = allChannels
    .filter(c => !q || c.name.toLowerCase().includes(q))
    .slice(0, 8);
  showSuggestions('channel-suggestions', filtered, ch => {
    setSelectedChannel(ch);
    fetchThreads(ch.id);
  });
}

document.getElementById('channel-search').addEventListener('focus', function () {
  showChannelSuggestions('');
});

document.getElementById('channel-search').addEventListener('input', function () {
  showChannelSuggestions(this.value.toLowerCase());
});

document.getElementById('channel-search').addEventListener('blur', () => {
  setTimeout(() => hideSuggestions('channel-suggestions'), 150);
});

async function fetchThreads(channelId) {
  const loadingEl = document.getElementById('loading-threads');
  const errEl = document.getElementById('threads-error');
  const searchInput = document.getElementById('thread-search');
  loadingEl.style.display = 'block';
  errEl.style.display = 'none';
  searchInput.value = '';
  allThreads = [];
  try {
    const res = await fetch('/api/discord/threads?channelId=' + encodeURIComponent(channelId));
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    allThreads = data.threads || [];
    loadingEl.style.display = 'none';
    if (!_initialThreadPrePopDone) {
      _initialThreadPrePopDone = true;
      if (INITIAL_FORUM_ID && INITIAL_FORUM_ID !== channelId) {
        const threadMatch = allThreads.find(t => t.id === INITIAL_FORUM_ID);
        if (threadMatch) selectThread(threadMatch);
      }
    }
  } catch {
    loadingEl.style.display = 'none';
    errEl.textContent = 'Failed to load threads.';
    errEl.style.display = 'block';
  }
}

function showThreadSuggestions(q) {
  const filtered = allThreads
    .filter(t => !q || t.name.toLowerCase().includes(q))
    .slice(0, 8);
  showSuggestions('thread-suggestions', filtered, selectThread);
}

document.getElementById('thread-search').addEventListener('focus', function () {
  showThreadSuggestions('');
});

document.getElementById('thread-search').addEventListener('input', function () {
  showThreadSuggestions(this.value.toLowerCase());
});

document.getElementById('thread-search').addEventListener('blur', () => {
  setTimeout(() => hideSuggestions('thread-suggestions'), 150);
});

function selectThread(thread) {
  selectedThread = thread;
  updateThreadChip();
  document.getElementById('thread-search').value = '';
  hideSuggestions('thread-suggestions');
}

function clearThread() {
  selectedThread = null;
  updateThreadChip();
}

function updateThreadChip() {
  const wrap = document.getElementById('selected-thread-wrap');
  if (selectedThread) {
    document.getElementById('selected-thread-name').textContent = selectedThread.name;
    wrap.style.display = '';
  } else {
    wrap.style.display = 'none';
  }
}

async function saveChannel() {
  const id = selectedThread ? selectedThread.id : (selectedChannel ? selectedChannel.id : '');
  const r = await apiPost('/api/settings', { tracked_forum_id: id });
  showMsg(r.ok ? 'Channel saved!' : (r.error || 'Error'), !r.ok);
}

// ── Multi-vote mode ──────────────────────────────────────────────────────────

document.getElementById('form-mode').addEventListener('submit', async e => {
  e.preventDefault();
  const mode = document.querySelector('input[name="multi_vote_mode"]:checked')?.value;
  const r = await apiPost('/api/settings', { multi_vote_mode: mode });
  showMsg(r.ok ? 'Mode saved!' : (r.error || 'Error'), !r.ok);
});

// ── Emojis ───────────────────────────────────────────────────────────────────

document.getElementById('form-emojis').addEventListener('submit', async e => {
  e.preventDefault();
  const vote_emojis = [0,1,2,3,4].map(i => document.querySelector(`input[name="emoji_${i}"]`).value.trim());
  const vote_emoji_weights = [0,1,2,3,4].map(i => {
    const v = parseFloat(document.querySelector(`input[name="emoji_weight_${i}"]`).value);
    return (isFinite(v) && v >= 0) ? v : i;
  });
  const r = await apiPost('/api/settings', { vote_emojis, vote_emoji_weights });
  showMsg(r.ok ? 'Emojis saved!' : (r.error || 'Error'), !r.ok);
});

// ── Password ─────────────────────────────────────────────────────────────────

document.getElementById('form-password').addEventListener('submit', async e => {
  e.preventDefault();
  const currentPassword = document.getElementById('currentPassword').value;
  const newPassword = document.getElementById('newPassword').value;
  const msg = document.getElementById('pw-msg');
  const r = await apiPost('/api/settings/password', { currentPassword, newPassword });
  if (r.ok) {
    msg.textContent = '✓ Password changed';
    msg.style.color = 'var(--success)';
    document.getElementById('currentPassword').value = '';
    document.getElementById('newPassword').value = '';
  } else {
    msg.textContent = '✗ ' + (r.error || 'Error');
    msg.style.color = 'var(--danger)';
  }
});

// ── Init ─────────────────────────────────────────────────────────────────────

loadRoles();
loadChannels();
</script>

<%- include('partials/footer') %>
