<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Voting Dashboard</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #1a1a2e;
      --surface: #16213e;
      --surface2: #0f3460;
      --accent: #7289da;
      --accent-hover: #5a6fbf;
      --text: #e0e0f0;
      --text-muted: #8a8aaa;
      --danger: #e74c3c;
      --success: #2ecc71;
      --border: #2a2a4a;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { color: var(--accent-hover); }

    /* ── Nav ── */
    nav {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      height: 56px;
    }

    .nav-brand {
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--accent);
      margin-right: auto;
      letter-spacing: 0.03em;
    }

    nav a {
      color: var(--text-muted);
      font-size: 0.9rem;
      padding: 4px 10px;
      border-radius: 6px;
      transition: background 0.15s, color 0.15s;
    }
    nav a:hover, nav a.active {
      background: var(--surface2);
      color: var(--text);
    }
    nav a.logout { color: var(--danger); }
    nav a.logout:hover { background: rgba(231,76,60,0.15); }

    /* ── Main content ── */
    main {
      flex: 1;
      padding: 2rem;
      max-width: 1200px;
      width: 100%;
      margin: 0 auto;
    }

    h1, h2 { color: var(--text); margin-bottom: 1rem; }
    h1 { font-size: 1.6rem; }
    h2 { font-size: 1.2rem; }

    /* ── Tables ── */
    .table-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
    }

    thead th {
      background: var(--surface2);
      color: var(--text-muted);
      text-transform: uppercase;
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      padding: 10px 14px;
      text-align: left;
      white-space: nowrap;
    }

    tbody tr {
      border-top: 1px solid var(--border);
      transition: background 0.1s;
    }
    tbody tr:hover { background: rgba(114,137,218,0.06); }

    td { padding: 10px 14px; vertical-align: middle; }

    .avatar {
      width: 28px; height: 28px;
      border-radius: 50%;
      object-fit: cover;
      vertical-align: middle;
      margin-right: 8px;
    }
    .avatar-placeholder {
      display: inline-block;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--surface2);
      vertical-align: middle;
      margin-right: 8px;
    }

    /* ── Cards / stat boxes ── */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 1rem;
      margin-bottom: 1.8rem;
    }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem 1.2rem;
    }
    .stat-card .label { color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; }
    .stat-card .value { font-size: 1.8rem; font-weight: 700; color: var(--accent); margin-top: 4px; }

    /* ── Timeframe tabs ── */
    .timeframe-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .timeframe-tabs a {
      padding: 6px 16px;
      border-radius: 20px;
      border: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.82rem;
      transition: all 0.15s;
    }
    .timeframe-tabs a:hover { border-color: var(--accent); color: var(--accent); }
    .timeframe-tabs a.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    /* ── Pagination ── */
    .pagination { display: flex; gap: 0.4rem; margin-top: 1.2rem; flex-wrap: wrap; }
    .pagination a, .pagination span {
      padding: 6px 12px;
      border-radius: 6px;
      border: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.82rem;
    }
    .pagination a:hover { border-color: var(--accent); color: var(--accent); }
    .pagination span.current {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    /* ── Forms ── */
    .form-group { margin-bottom: 1rem; }
    label { display: block; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 4px; }
    input[type="text"], input[type="password"], select, textarea {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      padding: 8px 12px;
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.15s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--accent); }

    .btn {
      display: inline-block;
      padding: 8px 20px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 600;
      transition: background 0.15s;
    }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-danger { background: var(--danger); color: #fff; }
    .btn-danger:hover { background: #c0392b; }

    .alert { padding: 10px 14px; border-radius: 6px; margin-bottom: 1rem; font-size: 0.88rem; }
    .alert-error { background: rgba(231,76,60,0.15); border: 1px solid var(--danger); color: #ff8a80; }
    .alert-success { background: rgba(46,204,113,0.12); border: 1px solid var(--success); color: #69f0ae; }

    /* ── Two-column grid for leaderboard ── */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media (max-width: 800px) { .two-col { grid-template-columns: 1fr; } }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.2rem;
    }

    .deleted-badge {
      font-size: 0.7rem;
      background: rgba(231,76,60,0.2);
      color: #ff8a80;
      border-radius: 4px;
      padding: 2px 6px;
    }

    /* ── Settings sections ── */
    .settings-section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.4rem;
      margin-bottom: 1.5rem;
    }
    .settings-section h2 { margin-bottom: 1.2rem; font-size: 1rem; color: var(--accent); }

    .emoji-row { display: flex; gap: 0.8rem; flex-wrap: wrap; }
    .emoji-row .form-group { flex: 1; min-width: 80px; }

    .role-list { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.8rem; }
    .role-item {
      display: flex; gap: 0.5rem; align-items: center;
      background: var(--surface2);
      border-radius: 6px;
      padding: 6px 10px;
    }
    .role-item input { flex: 1; }
    .role-item .rm-btn {
      background: none; border: none; color: var(--danger); cursor: pointer; font-size: 1.1rem; line-height: 1;
    }
  </style>
</head>
<body>
  <nav>
    <span class="nav-brand">Voting Dashboard</span>
    <a href="/leaderboard" class="<%= locals.page === 'leaderboard' ? 'active' : '' %>">Leaderboard</a>
    <a href="/posts" class="<%= locals.page === 'posts' ? 'active' : '' %>">Posts</a>
    <a href="/settings" class="<%= locals.page === 'settings' ? 'active' : '' %>">Settings</a>
    <a href="/logout" class="logout">Logout</a>
  </nav>
  <main>
