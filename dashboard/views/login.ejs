<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — Voting Dashboard</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #1a1a2e; --surface: #16213e; --surface2: #0f3460;
      --accent: #7289da; --accent-hover: #5a6fbf;
      --text: #e0e0f0; --text-muted: #8a8aaa;
      --danger: #e74c3c; --border: #2a2a4a;
    }
    body {
      background: var(--bg); color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif;
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
    }
    .login-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 2.5rem 2rem; width: 100%; max-width: 380px;
    }
    .brand { text-align: center; margin-bottom: 2rem; }
    .brand h1 { font-size: 1.5rem; color: var(--accent); }
    .brand p { font-size: 0.82rem; color: var(--text-muted); margin-top: 4px; }
    .form-group { margin-bottom: 1.2rem; }
    label { display: block; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 6px; }
    input[type="password"] {
      width: 100%; background: var(--surface2); border: 1px solid var(--border);
      border-radius: 6px; color: var(--text); padding: 10px 14px;
      font-size: 0.95rem; outline: none; transition: border-color 0.15s;
    }
    input[type="password"]:focus { border-color: var(--accent); }
    .btn {
      width: 100%; padding: 10px; border-radius: 6px; border: none;
      background: var(--accent); color: #fff; font-size: 0.95rem;
      font-weight: 600; cursor: pointer; transition: background 0.15s;
    }
    .btn:hover { background: var(--accent-hover); }
    .alert {
      padding: 10px 14px; border-radius: 6px; margin-bottom: 1.2rem;
      font-size: 0.85rem;
      background: rgba(231,76,60,0.15); border: 1px solid var(--danger); color: #ff8a80;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="brand">
      <h1>⚡ Voting Dashboard</h1>
      <p>Enter your password to continue</p>
    </div>
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>
    <form method="POST" action="/login" autocomplete="off">
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autofocus autocomplete="current-password" required />
      </div>
      <button type="submit" class="btn">Log In</button>
    </form>
  </div>
</body>
</html>
