<%- include('partials/header', { page: 'posts' }) %>

<h1>Posts</h1>

<!-- Timeframe tabs -->
<div class="timeframe-tabs">
  <% ['24h','7d','30d','90d','all'].forEach(tf => { %>
    <a href="/posts?timeframe=<%= tf %>&page=1"
       class="<%= timeframe === tf ? 'active' : '' %>">
      <%= tf === '24h' ? '24h' : tf === '7d' ? '7 days' : tf === '30d' ? '30 days' : tf === '90d' ? '90 days' : 'All time' %>
    </a>
  <% }) %>
</div>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Author</th>
        <th>Content Preview</th>
        <th>Posted</th>
        <th>Score</th>
        <th>Voters</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% if (posts.length === 0) { %>
        <tr><td colspan="7" style="color:var(--text-muted);text-align:center;padding:2rem;">No posts found</td></tr>
      <% } %>
      <% posts.forEach((post, i) => {
           const rowNum = (page - 1) * 20 + i + 1;
           const preview = post.content ? post.content.substring(0, 150) + (post.content.length > 150 ? '…' : '') : '—';
           const postedDate = new Date(post.postedAt).toLocaleString();
           const discordUrl = post.guildId
             ? `https://discord.com/channels/${post.guildId}/${post.threadId}/${post.messageId}`
             : null;
      %>
        <tr style="cursor:<%= discordUrl ? 'pointer' : 'default' %>"
            <% if (discordUrl) { %>onclick="window.open('<%= discordUrl %>', '_blank')"<% } %>>
          <td style="color:var(--text-muted)"><%= rowNum %></td>
          <td><%= post.displayName %></td>
          <td style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
            <span title="<%= (post.content || '').replace(/"/g, '&quot;') %>"><%= preview %></span>
          </td>
          <td style="color:var(--text-muted);white-space:nowrap"><%= postedDate %></td>
          <td style="color:var(--accent);font-weight:700"><%= Number(post.totalScore || 0).toFixed(1).replace(/\.0$/, '') %></td>
          <td><%= post.voteCount %></td>
          <td>
            <% if (post.deleted) { %>
              <span class="deleted-badge">deleted</span>
            <% } else { %>
              <span style="color:var(--success);font-size:0.8rem">active</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<div class="pagination">
  <% if (page > 1) { %>
    <a href="/posts?timeframe=<%= timeframe %>&page=<%= page - 1 %>">‹ Prev</a>
  <% } %>

  <% for (let p = Math.max(1, page - 3); p <= Math.min(totalPages, page + 3); p++) { %>
    <% if (p === page) { %>
      <span class="current"><%= p %></span>
    <% } else { %>
      <a href="/posts?timeframe=<%= timeframe %>&page=<%= p %>"><%= p %></a>
    <% } %>
  <% } %>

  <% if (page < totalPages) { %>
    <a href="/posts?timeframe=<%= timeframe %>&page=<%= page + 1 %>">Next ›</a>
  <% } %>
</div>
<% } %>

<%- include('partials/footer') %>
